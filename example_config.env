# Maven Decoder MCP Server Configuration
# Copy this file to .env or set these environment variables

# Maven repository location (default: ~/.m2/repository)
MAVEN_HOME=~/.m2/repository

# Logging level (DEBUG, INFO, WARNING, ERROR)
MCP_LOG_LEVEL=INFO

# Response Management Configuration
# Maximum response size in bytes before pagination (default: 50000)
MCP_MAX_RESPONSE_SIZE=50000

# Default items per page for pagination (default: 20)
MCP_MAX_ITEMS_PER_PAGE=20

# Maximum text length before summarization (default: 10000)
MCP_MAX_TEXT_LENGTH=10000

# Maximum lines before summarization (default: 500)
MCP_MAX_LINES=500

# Example configurations for different use cases:

# For large repositories (more aggressive pagination)
# MCP_MAX_RESPONSE_SIZE=30000
# MCP_MAX_ITEMS_PER_PAGE=10
# MCP_MAX_TEXT_LENGTH=5000
# MCP_MAX_LINES=200

# For detailed analysis (less aggressive pagination)
# MCP_MAX_RESPONSE_SIZE=100000
# MCP_MAX_ITEMS_PER_PAGE=50
# MCP_MAX_TEXT_LENGTH=20000
# MCP_MAX_LINES=1000
